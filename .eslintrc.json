{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "no-unused-vars": ["warn", {
      "vars": "all",
      "args": "none",
      "ignoreRestSiblings": true
    }],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "prefer-const": "error",
    "react/self-closing-comp": "warn"
  }
}
